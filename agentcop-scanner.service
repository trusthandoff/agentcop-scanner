[Unit]
Description=AgentCop Security Scanner
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/agentcop-scanner
EnvironmentFile=/root/agentcop-scanner/.env
ExecStart=/root/agentcop-scanner/.venv/bin/uvicorn main:app --host 0.0.0.0 --port 8080
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
